# Sportmonks API
SPORTMONKS_API_KEY=your_sportmonks_api_key_here

# Odds API (the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional overrides
TIMEZONE=Europe/London
PREDICTION_RUN_TIME=09:00

# Prediction Mode Settings
# PREDICTION_MODE: "stat" (statistics only), "ml" (ML only), "hybrid" (combined), or "ensemble"
PREDICTION_MODE=ensemble

# Number of recent matches to use for form calculation (3–7 recommended)
FORM_MATCH_WINDOW=5

# ML settings
# Number of past seasons to use for ML training (default: 3)
HISTORICAL_SEASONS=3

# ML settings
# Weight of ML prediction in hybrid mode (0.0-1.0, remainder goes to stat-based)
# Default 0.5 means 50% ML + 50% statistics
ML_WEIGHT=0.5

# Ensemble model weights (RF, GB, LR, XGBoost, CatBoost, SVM — should sum to ~1.0)
ENSEMBLE_RF_WEIGHT=0.15
ENSEMBLE_GB_WEIGHT=0.15
ENSEMBLE_LR_WEIGHT=0.05
ENSEMBLE_XGB_WEIGHT=0.30
ENSEMBLE_CB_WEIGHT=0.30
ENSEMBLE_SVM_WEIGHT=0.10

# Ensemble voting mode: "soft" (weighted average probabilities) | "hard" (majority class vote)
ENSEMBLE_MODE=soft
